{
  "logging": {
    "logs": {
      "default": {
        "writer": {
          "output": "stdout"
        },
        "encoder": {
          "format": "console"
        }
      }
    }
  },
  "storage": {
    "module": "file_system",
    "root": "/caddydata"
  },
  "apps": {
    "tls": {
      "automation": {
        "policies": [
          {
            "issuers": [
              {
                "module": "acme",
                "ca": "https://acme.burble.dn42/v1/dn42/acme/directory",
                "test_ca": "https://acme.burble.dn42/v1/staging/acme/directory",
                "email": "i@exploro.one",
                "acme_timeout": "300s",
                "challenges": {
                  "http": {
                    "disabled": false
                  },
                  "tls-alpn": {
                    "disabled": true
                  }
                },
                "trusted_roots_pem_files": ["/dn42-root-ca.crt"]
              }
            ]
          }
        ]
      }
    },
    "http": {
      "servers": {
        "main": {
          "listen": [":443", ":80"],
          "routes": [
            {
              "match": [
                {
                  "host": ["chat.dn42"]
                }
              ],
              "handle": [
                {
                  "handler": "file_server",
                  "root": "/usr/share/nginx/html"
                }
              ]
            },
            {
              "match": [
                {
                  "host": ["chat.duststars.dn42"],
                  "path": ["/api/*"]
                }
              ],
              "handle": [
                {
                  "handler": "headers",
                  "response": {
                    "delete": ["X-Origin-Pass"],
                    "deferred": true
                  }
                },
                {
                  "handler": "headers",
                  "response": {
                    "set": {
                      "Access-Control-Allow-Origin": [
                        "{http.request.header.Origin}"
                      ],
                      "Access-Control-Allow-Methods": [
                        "GET, POST, PUT, DELETE, OPTIONS"
                      ],
                      "Access-Control-Allow-Credentials": ["true"],
                      "Vary": ["Origin"]
                    },
                    "deferred": true,
                    "require": {
                      "headers": {
                        "X-Origin-Pass": ["true"]
                      }
                    }
                  }
                },
                {
                  "handler": "map",
                  "source": "{http.request.header.Origin}",
                  "destinations": ["{vars.origin_pass}"],
                  "defaults": [""],
                  "mappings": [
                    {
                      "input_regexp": "^https?://localhost(:[0-9]+)?$",
                      "outputs": ["true"]
                    },
                    {
                      "input_regexp": "^https?://chat\\.duststars\\.dn42(:[0-9]+)?$",
                      "outputs": ["true"]
                    },
                    {
                      "input_regexp": "^https?://chat\\.dn42(:[0-9]+)?$",
                      "outputs": ["true"]
                    }
                  ]
                },
                {
                  "handler": "headers",
                  "response": {
                    "add": {
                      "X-Origin-Pass": ["{vars.origin_pass}"]
                    },
                    "deferred": true
                  }
                },
                {
                  "handler": "reverse_proxy",
                  "upstreams": [
                    {
                      "dial": "dn42-webrtc-server:3001"
                    }
                  ],
                  "rewrite": {
                    "strip_path_prefix": "/api"
                  }
                }
              ]
            }
          ]
        }
      }
    }
  }
}
