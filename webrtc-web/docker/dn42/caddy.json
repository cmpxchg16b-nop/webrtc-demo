{
  "admin": {
    "listen": "{env.CADDY_ADMIN_ADDR}"
  },
  "logging": {
    "logs": {
      "default": {
        "writer": {
          "output": "stdout"
        },
        "encoder": {
          "format": "console"
        }
      }
    }
  },
  "storage": {
    "module": "file_system",
    "root": "/caddydata"
  },
  "apps": {
    "tls": {
      "automation": {
        "policies": [
          {
            "issuers": [
              {
                "module": "acme",
                "ca": "https://acme.burble.dn42/v1/dn42/acme/directory",
                "test_ca": "https://acme.burble.dn42/v1/staging/acme/directory",
                "email": "{env.ACME_CONTACT_EMAIL}",
                "acme_timeout": "300s",
                "challenges": {
                  "http": {
                    "disabled": false
                  },
                  "tls-alpn": {
                    "disabled": true
                  }
                },
                "trusted_roots_pem_files": ["/dn42-root-ca.crt"]
              }
            ]
          }
        ]
      }
    }
  }
}
